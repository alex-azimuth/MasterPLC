{"CLs":[{"__type":"LD","Var":"Gag_Fault_Conditions"},{"__type":"IST","EID":"cd2b8fdd-8c52-46b7-a71b-ad1f4e72d635","H":819.5999999999998,"Ix":1,"TXT":"Gag_Fault := FALSE;\u000d\u000aHMI_Feeder_Data.Gag_Fault_Msg := '';\u000d\u000a\u000d\u000aIF ((Sequence_No > 0) OR (Act_Sequences.Gag[0] <> 0)) \u000d\u000a\u0009AND (HMI_Die_Config.Gag_Confirmed) THEN\u000d\u000a\u0009(* Assure that the gag has activated as it should be *)\u000d\u000a\u0009FOR II:=1 TO No_Gags_Installed BY 1 DO\u000d\u000a\u0009\u0009\/\/ Do not validate that a gag is activated if our feed is currently paused\u000d\u000a\u0009\u0009IF ((Gags[II]) AND NOT (Pause_Feed)) AND HMI_Die_Config.Extend_Confirmed THEN\u000d\u000a\u0009\u0009\u0009(* Current gag has to be activated *)\u000d\u000a\u0009\u0009\u0009IF ((Gag_Pro[II] <> TRUE) OR (Gag_Ret[II] = TRUE)) THEN\u000d\u000a\u0009\u0009\u0009\u0009Gag_Fault := TRUE;\u000d\u000a\u0009\u0009\u0009\u0009\u000d\u000a\u0009\u0009\u0009\u0009Gag_Faults_Act[II] := TRUE;\u000d\u000a\u0009\u0009\u0009\u0009Gag_Faults_Act_R[II](CLK := Gag_Faults_Act[II]);\u000d\u000a\u0009\u0009\u0009\u0009IF (Gag_Faults_Act[II]) THEN\u000d\u000a\u0009\u0009\u0009\u0009\u0009Str_List_Push(Gag_Messages, CONCAT('Extend fail: ', Get_Gag_Name(II-1, HMI_Die_Config), ';    '));\u000d\u000a\u0009\u0009\u0009\u0009END_IF;\u000d\u000a\u0009\u0009\u0009END_IF;\u000d\u000a\u0009\u0009ELSE\u000d\u000a\u0009\u0009\u0009(* All other gags must be deactivated *)\u000d\u000a\u0009\u0009\u0009\/\/ This is true even when we are paused, all gags must successfully deactivate\u000d\u000a\u0009\u0009\u0009IF ((Gag_Pro[II] = TRUE) OR (Gag_Ret[II] <> TRUE)) AND HMI_Die_Config.Retract_Confirmed THEN\u000d\u000a\u0009\u0009\u0009\u0009Gag_Fault := TRUE;\u000d\u000a\u0009\u0009\u0009\u0009\u000d\u000a\u0009\u0009\u0009\u0009Gag_Faults_Deact[II] := TRUE;\u000d\u000a\u0009\u0009\u0009\u0009Gag_Faults_Deact_R[II](CLK := Gag_Faults_Deact[II]);\u000d\u000a\u0009\u0009\u0009\u0009IF (Gag_Faults_Deact[II]) THEN\u000d\u000a\u0009\u0009\u0009\u0009\u0009Str_List_Push(Gag_Messages, CONCAT('Retract fail: ', Get_Gag_Name(II-1, HMI_Die_Config), ';    '));\u000d\u000a\u0009\u0009\u0009\u0009END_IF;\u000d\u000a\u0009\u0009\u0009END_IF;\u000d\u000a\u0009\u0009END_IF;\u000d\u000a\u0009END_FOR;\u000d\u000aELSIF (NOT HMI_Die_Config.Gag_Confirmed) THEN\u000d\u000a\u0009Gag_Fault := FALSE;\u000d\u000a\u0009Gag_Faults_Act := Gag_Faults_Empty;\u000d\u000a\u0009Gag_Faults_Deact := Gag_Faults_Empty;\u000d\u000a\u0009Gag_Messages := Gag_Messages_Empty;\u000d\u000aEND_IF;\u000d\u000a\u000d\u000aHMI_Feeder_Data.Gag_Fault_Msg := CONCAT(Gag_Messages.Str_List[0], Gag_Messages.Str_List[1], Gag_Messages.Str_List[2], Gag_Messages.Str_List[3]);","W":949.59999999999991,"X":1}],"CMT":"If you lose your feed signal or the gag delay has been exhausted then give an alarm if the gag has not activated as it should.","LRI":2,"RRI":3,"VLs":[]}
