{"CLs":[{"__type":"IST","EID":"3de968b4-f4d5-43b9-a0ca-04036abc538a","H":1957.1999999999991,"TXT":"\/\/ Make sure we display the raw value on the screen\u000d\u000aHMI_Data_Uncoiler.AI_Raw_Value := HMI_Data_Uncoiler.IOL_Current_Distance;\u000d\u000a\u000d\u000aIF (Master_Uncoiler_Options.IOL_Sensors) THEN\u000d\u000a\u0009HMI_Data_Uncoiler.IOL_Current_Distance := (TO_REAL(Uncoiler_ABB_AI1_Value)+HMI_Data_Uncoiler_Retained.AI_Offset)*HMI_Data_Uncoiler_Retained.AI_Multiplier;\u000d\u000a\u0009\u0009\u000d\u000a\u0009\/\/ Impose limits\u000d\u000a\u0009IF (HMI_Data_Uncoiler.AI_Raw_Value > HMI_Data_Uncoiler_Retained.AI_Scale_Raw_High) THEN\u000d\u000a\u0009\u0009Value := HMI_Data_Uncoiler_Retained.AI_Scale_Raw_High;\u000d\u000a\u0009ELSE\u000d\u000a\u0009\u0009Value := HMI_Data_Uncoiler.AI_Raw_Value;\u000d\u000a\u0009END_IF;\u000d\u000a\u000d\u000a\u0009IF (HMI_Data_Uncoiler.AI_Raw_Value < HMI_Data_Uncoiler_Retained.AI_Scale_Raw_Low) THEN\u000d\u000a\u0009\u0009Value := HMI_Data_Uncoiler_Retained.AI_Scale_Raw_Low;\u000d\u000a\u0009ELSE\u000d\u000a\u0009\u0009Value := HMI_Data_Uncoiler.AI_Raw_Value;\u000d\u000a\u0009END_IF;\u000d\u000a\u0009\u0009\u000d\u000a(*\u0009\/\/ Transform raw data into scaled Hz value\u000d\u000a\u0009Speed_Value  := ScaleTrans(SclIN:=Value,\u000d\u000a\u0009\u0009\u0009   \u0009\u0009  X0:=HMI_Data_Uncoiler_Retained.AI_Scale_Raw_Low,\u000d\u000a\u0009\u0009\u0009\u0009\u0009  X1:=HMI_Data_Uncoiler_Retained.AI_Scale_Raw_High,\u000d\u000a\u0009\u0009\u0009\u0009\u0009  Y0:=HMI_Data_Uncoiler_Retained.AI_Scale_Speed_Low,\u000d\u000a\u0009\u0009\u0009\u0009\u0009  Y1:=HMI_Data_Uncoiler_Retained.AI_Scale_Speed_High);*)\u000d\u000a\u000d\u000a(*\u0009\/\/ If one of the ranges is inverted then consider we need to start the uncoiler from the other direction\u000d\u000a\u0009IF ((HMI_Data_Uncoiler_Retained.AI_Scale_Speed_Low > HMI_Data_Uncoiler_Retained.AI_Scale_Speed_High) AND\u000d\u000a\u0009\u0009(HMI_Data_Uncoiler_Retained.AI_Scale_Raw_Low < HMI_Data_Uncoiler_Retained.AI_Scale_Raw_High)) OR\u000d\u000a\u0009\u0009((HMI_Data_Uncoiler_Retained.AI_Scale_Speed_Low < HMI_Data_Uncoiler_Retained.AI_Scale_Speed_High) AND\u000d\u000a\u0009\u0009(HMI_Data_Uncoiler_Retained.AI_Scale_Raw_Low > HMI_Data_Uncoiler_Retained.AI_Scale_Raw_High)) THEN\u000d\u000a\u0009\u0009Highest_Val := HMI_Data_Uncoiler_Retained.AI_Scale_Speed_Low;\u000d\u000a\u0009\u0009Lowest_Val := HMI_Data_Uncoiler_Retained.AI_Scale_Speed_High;\u000d\u000a\u0009\u0009Switch_Val := TRUE;\u000d\u000a\u0009ELSE\u000d\u000a\u0009\u0009Highest_Val := HMI_Data_Uncoiler_Retained.AI_Scale_Speed_High;\u000d\u000a\u0009\u0009Lowest_Val := HMI_Data_Uncoiler_Retained.AI_Scale_Speed_Low;\u000d\u000a\u0009\u0009Switch_Val := FALSE;\u000d\u000a\u0009END_IF;*)\u000d\u000a\u0009\u000d\u000a\u0009\/\/ Calculate the distance from the ground up, instead of from the perpective of the sensor pointing down.\u000d\u000a\u0009IF (NOT HMI_Data_Uncoiler_Retained.Sensor_Below_Mounted) THEN\u000d\u000a\u0009\u0009Loop_Height := HMI_Data_Uncoiler_Retained.Sensor_Height-Value;\u000d\u000a\u0009ELSE\u000d\u000a\u0009\u0009Loop_Height := Value;\u000d\u000a\u0009END_IF;\u000d\u000a\u0009\u000d\u000a\u0009\/\/ Setpoint is the current lowest value of the loop, anything above that is an error\u000d\u000a\u0009Setpoint := HMI_Data_Uncoiler_Retained.AI_Scale_Raw_Low;\u000d\u000a\u0009\/\/ Calculate the error based on current loop height and the setpoint\u000d\u000a\u0009Error := Loop_Height-Setpoint;\u000d\u000a\u000d\u000a\u0009\/\/ Make sure we do not apply a minimum speed if error is 0 or below\u000d\u000a\u0009IF (Error > 0) THEN\u000d\u000a\u0009\u0009\/\/ Find speed value as per actual error\u000d\u000a\u0009\u0009(*Out := ((SafeDiv_REAL(Error, (HMI_Data_Uncoiler_Retained.AI_Scale_Raw_High-HMI_Data_Uncoiler_Retained.AI_Scale_Raw_Low))*\u000d\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009 (HMI_Data_Uncoiler_Retained.AI_Scale_Speed_High-HMI_Data_Uncoiler_Retained.AI_Scale_Raw_Low)))+\u000d\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009 (HMI_Data_Uncoiler_Retained.AI_Scale_Raw_Low);*)\u000d\u000a\u0009\u0009\/\/ Out value in RPM error multiplied by gain is speed\u000d\u000a\u0009\u0009Speed_Value := Error* HMI_Data_Uncoiler_Retained.Prop_Gain;\u000d\u000a\u0009ELSE\u000d\u000a\u0009\u0009Speed_Value := 0;\u000d\u000a\u0009END_IF;\u000d\u000a\u000d\u000a\u0009\/\/ Limit the maximum speed at the total range of the scaling\u000d\u000a\u0009IF (Speed_Value > HMI_Data_Uncoiler_Retained.AI_Scale_Speed_High) THEN\u000d\u000a\u0009\u0009Speed_Value_Lim := HMI_Data_Uncoiler_Retained.AI_Scale_Speed_High;\u000d\u000a\u0009ELSIF (Speed_Value < HMI_Data_Uncoiler_Retained.AI_Scale_Raw_Low) THEN\u000d\u000a\u0009\u0009Speed_Value_Lim := HMI_Data_Uncoiler_Retained.AI_Scale_Raw_Low;\u000d\u000a\u0009ELSE\u000d\u000a\u0009\u0009Speed_Value_Lim := Speed_Value;\u000d\u000a\u0009END_IF;\u000d\u000a\u000d\u000a\u0009Size_Ary := (SizeOfAry(Val_Array))-1;\u000d\u000a\u0009\/\/ Store all values in an array\u000d\u000a\u0009IF (Iterator_SPD < Size_Ary) THEN\u000d\u000a\u0009\u0009Val_Array[Iterator_SPD] := Speed_Value_Lim;\u000d\u000a\u0009\u0009Iterator_SPD := Iterator_SPD+1;\u000d\u000a\u0009ELSE\u000d\u000a\u0009\u0009\u0009Iterator_SPD := 0;\u000d\u000a\u0009END_IF;\u000d\u000a\u0009\u000d\u000a\u0009\/\/ Calculate the average value to prevent momentary anomalous readings of the sensor\u000d\u000a\u0009Val_Average := 0;\u000d\u000a\u0009FOR J:=0 TO Size_Ary DO\u000d\u000a\u0009\u0009Val_Average := Val_Average+TO_REAL(Val_Array[J]);\u000d\u000a\u0009END_FOR;\u000d\u000a\u0009\u0009\u000d\u000a\u0009Val_Average := SafeDiv_Real(Val_Average, Size_Ary);\u000d\u000a\u0009\u0009\u000d\u000a\u0009HMI_Data_Uncoiler.Uncoiler_Scaled_Speed := Val_Average;\u000d\u000a\u0009\u000d\u000a\u0009\/\/ Make sure that if we go above our deadzone then we use the highest value possible\u000d\u000a\u0009\/\/ Prevents the uncoiler from just stopping when reaching the deadzone\u000d\u000a\u0009IF (Uncoiler_IN_On_Signal) THEN\u000d\u000a\u0009\u0009HMI_Data_Uncoiler.Uncoiler_Scaled_Speed := Highest_Val;\u000d\u000a\u0009END_IF;\u000d\u000a\u0009\u000d\u000a\u0009\/\/ Start the uncoiler whenever we have an error above 0\u000d\u000a\u0009IOL_Uncoiler_Signal := Error > 0;\u000d\u000aEND_IF;","W":1535.9999999999995}],"LRI":1,"RRI":2,"VLs":[]}
