{"CLs":[{"__type":"IST","EID":"e6441359-df01-4a6f-b7f4-f8de14de3fe0","H":1818.8000000000002,"TXT":"\/\/ Initialize everything to false\u000d\u000aFOR I:=0 TO 15 DO\u000d\u000a\u0009Press_OUT_Cams[I] := FALSE;\u000d\u000aEND_FOR;\u000d\u000aIF (Press_Idle) THEN\u000d\u000a\u0009UIO_Top_Stop := FALSE;\u000d\u000aEND_IF;\u000d\u000aUIO_Stop := FALSE;\u000d\u000aUIO_Abort_Feed := FALSE;\u000d\u000a\u000d\u000aUIO_Message_Display := '';\u000d\u000a\u000d\u000aIF (Actions_Active) THEN\u000d\u000a\u0009\/\/ Loop through the conditions and activate the user outputs as necessary\u000d\u000a\u0009FOR I:=0 TO END_INDEX DO\u000d\u000a\u0009\u0009\/\/ Loop through all cam outputs\u000d\u000a\u0009\u0009FOR Y:=0 TO 15 DO\u000d\u000a\u0009\u0009\u0009\/\/ Cam is not forced via HMI\u000d\u000a\u0009\u0009\u0009IF (UIO_Cam_Force[Y] = 0) THEN\u000d\u000a\u0009\u0009\u0009\u0009Press_OUT_Cams[Y] := My_Actions[I].Outputs[Y] OR Press_OUT_Cams[Y];\u000d\u000a\u0009\u0009\u0009\/\/ Cam is forced to off state by HMI\u000d\u000a\u0009\u0009\u0009ELSIF (UIO_Cam_Force[Y] = 1) THEN\u000d\u000a\u0009\u0009\u0009\u0009Press_OUT_Cams[Y] := FALSE;\u000d\u000a\u0009\u0009\u0009\/\/ Cam is forced to on state by HMI\u000d\u000a\u0009\u0009\u0009ELSIF (UIO_Cam_Force[Y] = 2) THEN\u000d\u000a\u0009\u0009\u0009\u0009Press_OUT_Cams[Y] := TRUE;\u000d\u000a\u0009\u0009\u0009END_IF;\u000d\u000a\u0009\u0009END_FOR;\u000d\u000a\u0009\u0009\u000d\u000a\u0009\u0009UIO_Abort_Feed := My_Actions[I].Abort_Feed OR UIO_Abort_Feed;\u000d\u000a\u0009\u0009UIO_Stop := My_Actions[I].Immediate_Stop OR (NOT My_Actions[I].Continue_Act) OR UIO_Stop;\u000d\u000a\u0009\u0009UIO_Top_Stop := My_Actions[I].Stop OR UIO_Top_Stop OR UIO_Abort_Feed;\u000d\u000a\u0009\u0009\u000d\u000a\u0009\u0009\/\/ Make sure all the start conditions are fullfilled\u000d\u000a\u0009\u0009IF (I < 1) THEN\u000d\u000a\u0009\u0009\u0009UIO_Start_Condition := My_Actions[0].Start_Condition;\u000d\u000a\u0009\u0009\u0009UIO_Start_Feed := My_Actions[0].Start_Feed;\u000d\u000a\u0009\u0009ELSE\u000d\u000a\u0009\u0009\u0009UIO_Start_Condition := My_Actions[I].Start_Condition AND UIO_Start_Condition;\u000d\u000a\u0009\u0009\u0009UIO_Start_Feed := My_Actions[I].Start_Feed AND UIO_Start_Feed;\u000d\u000a\u0009\u0009END_IF;\u000d\u000a\u0009\u0009\u000d\u000a\u0009\u0009Immediate_Stop_R[I](CLK := My_Actions[I].Immediate_Stop);\u000d\u000a\u0009\u0009Continue_R[I](CLK := NOT My_Actions[I].Continue_Act);\u000d\u000a\u0009\u0009Stop_R[I](CLK := My_Actions[I].Stop);\u000d\u000a\u0009\u0009Abort_Feed_R[I](CLK := My_Actions[I].Abort_Feed);\u000d\u000a\u0009\u0009Start_Condition_R[I](CLK := NOT My_Actions[I].Start_Condition);\u000d\u000a\u0009\u0009\u000d\u000a\u0009\u0009IF (Immediate_Stop_R[I].Q) THEN\u000d\u000a\u0009\u0009\u0009Str_List_Push(List := Message_Stack, \u000d\u000a\u0009\u0009\u0009Text_Add := CONCAT('Stop : ', Global_Conditions[I].Name, ';     '));\u000d\u000a\u0009\u0009ELSIF (Continue_R[I].Q) THEN\u000d\u000a\u0009\u0009\u0009Str_List_Push(List := Message_Stack, \u000d\u000a\u0009\u0009\u0009Text_Add := CONCAT('Continue : ', Global_Conditions[I].Name, ';     '));\u000d\u000a\u0009\u0009ELSIF (Stop_R[I].Q) THEN\u000d\u000a\u0009\u0009\u0009Str_List_Push(List := Message_Stack, \u000d\u000a\u0009\u0009\u0009Text_Add := CONCAT('Top Stop : ', Global_Conditions[I].Name, ';     '));\u000d\u000a\u0009\u0009ELSIF (Abort_Feed_R[I].Q) THEN\u000d\u000a\u0009\u0009\u0009Str_List_Push(List := Message_Stack, \u000d\u000a\u0009\u0009\u0009Text_Add := CONCAT('Abort Feed : ', Global_Conditions[I].Name, ';     '));\u000d\u000a\u0009\u0009ELSIF (Start_Condition_R[I].Q) THEN\u000d\u000a\u0009\u0009\u0009Str_List_Push(List := Message_Stack, \u000d\u000a\u0009\u0009\u0009Text_Add := CONCAT('Start Condition : ', Global_Conditions[I].Name, ';     '));\u000d\u000a\u0009\u0009END_IF;\u000d\u000a\u0009END_FOR;\u000d\u000aEND_IF;\u000d\u000a\u000d\u000a\/\/ Clear the message list upon alarm reset\u000d\u000aIF (HMI_Data.Alarm_Reset OR HMI2_Data.Alarm_Reset) THEN\u000d\u000a\u0009Message_Stack := Message_Stack_Empty;\u000d\u000aEND_IF;\u000d\u000a\/\/ Add messages to the display\u000d\u000aUIO_Message_Display := CONCAT(Message_Stack.Str_List[0], Message_Stack.Str_List[1], Message_Stack.Str_List[2], Message_Stack.Str_List[3], \u000d\u000a\u0009Message_Stack.Str_List[4]); \u000d\u000a\u000d\u000a\u000d\u000a\u000d\u000a\/\/ Only trigger a top stop if the press is not started since it is a start condition\u000d\u000aIF (NOT UIO_Start_Condition) AND Press_Idle  AND\u000d\u000a\u0009Actions_Active THEN\u000d\u000a\u0009UIO_Top_Stop_Start_Condition := TRUE;\u000d\u000aELSE\u000d\u000a\u0009UIO_Top_Stop_Start_Condition := FALSE;\u000d\u000aEND_IF;\u000d\u000a\u000d\u000a\/\/ Only trigger a start Feed if the feeder is not started since it is a start condition\u000d\u000aIF (NOT UIO_Start_Feed) AND (NOT Feeder_Signals.Feed_Busy)  AND\u000d\u000a\u0009NOT HMI_Feeder_Data.Manual_Feeding THEN\u000d\u000a\u0009UIO_Start_Feed_Condition := FALSE;\u000d\u000aELSE\u000d\u000a\u0009UIO_Start_Feed_Condition := TRUE;\u000d\u000aEND_IF;","W":1056}],"LRI":1,"RRI":2,"VLs":[]}
