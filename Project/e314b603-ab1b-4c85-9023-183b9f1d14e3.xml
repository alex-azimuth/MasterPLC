{"CLs":[{"__type":"LD","Var":"Master_Press_Options.S_Press"},{"__type":"IST","EID":"4b71340f-50cd-4122-bdba-b06dde74f2cf","H":352.4,"Ix":1,"TXT":"My_Overrides[0](Axis := S_Press, Enable := TRUE);\u000d\u000a\u000d\u000aOverride_Inactive := FALSE;\u000d\u000aFOR Override_I := 0 TO 31 DO\u000d\u000a\u0009IF (Global_Conditions[Override_I].Enabled AND My_Actions[Override_I].Speed_Cam AND Actions_Active) THEN\u000d\u000a\u0009\u0009My_Overrides[0].VelFactor := Global_Conditions[Override_I].T_OF;\u000d\u000a\u0009\u0009Override_Inactive := TRUE;\u000d\u000a\u0009END_IF;\u000d\u000aEND_FOR;\u000d\u000a\u000d\u000aIF NOT (Override_Inactive) THEN\u000d\u000a\u0009My_Overrides[0].VelFactor := 100;\u000d\u000aEND_IF;","W":746.4,"X":1}],"LRI":2,"RRI":3,"VLs":[]}
